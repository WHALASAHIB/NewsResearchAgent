# ════════════════════════════════════════════
# Quantum Alpha WhatsApp Agent — Environment
# Copy this to .env and fill in your keys
# ════════════════════════════════════════════

# ── TWILIO (Required) ──────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── AI ANALYSIS (Recommended) ─────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── NEWS SOURCES (Pick at least one) ──────

# Option A: NewsAPI — best for headlines
# Get from: https://newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Option B: Perplexity — best for research-grade search
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxx

# ── YOUR WHATSAPP NUMBER ───────────────────
# Add your number here for scheduled reports
YOUR_WHATSAPP_NUMBER=whatsapp:+61XXXXXXXXXX
