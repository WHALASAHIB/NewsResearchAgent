# ════════════════════════════════════════════════════
# QUANTUM ALPHA — .gitignore
# Personal workflow — keep ALL secrets off GitHub
# ════════════════════════════════════════════════════

# ─── NEVER commit these ───────────────────────────
.env
*.env
.env.*
!.env.example          # Allow the template (no real keys)
whatsapp_agent/.env
whatsapp_agent/logs/

# ─── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
pip-log.txt

# ─── Virtual Environments ─────────────────────────
venv/
.venv/
env/
ENV/

# ─── Secrets / Keys (belt & suspenders) ──────────
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
*.secret

# ─── Logs (may contain sensitive data) ───────────
*.log
logs/
whatsapp_agent/logs/

# ─── macOS ────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── IDE / Editor ─────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.bak

# ─── Jupyter (if used for analysis) ──────────────
.ipynb_checkpoints/

# ─── Temporary / scratch ─────────────────────────
tmp/
temp/
scratch/
